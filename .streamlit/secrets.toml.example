# Streamlit Secrets Configuration (for Khojo Fashion Recommender)
# 
# This file shows how to configure the dataset URL for cloud deployment.
# 
# On Streamlit Cloud:
# 1. Go to your app dashboard
# 2. Click "Settings" → "Secrets"
# 3. Paste the DATASET_URL below, replacing PLACEHOLDER with your actual URL
#
# For hosting the CSV:
# - Google Drive: Share the file, get ID, use: https://drive.google.com/uc?export=download&id=FILE_ID
# - AWS S3 / Heroku: Upload CSV and get a direct HTTPS URL
# - GitHub Raw: If file is < 100MB, upload to repo and use raw.githubusercontent.com URL
#
# Example configurations:
#
# DATASET_URL = "https://drive.google.com/uc?export=download&id=YOUR_FILE_ID"
# DATASET_PATH = "/mnt/data/myntra.csv"  (for local/mounted storage)

# Uncomment and fill in for cloud deployment:
# DATASET_URL = "YOUR_CSV_DOWNLOAD_URL_HERE"
